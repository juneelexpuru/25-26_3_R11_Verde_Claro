    {
        "id": "rl_fn_grid_loaded",
        "type": "function",
        "z": "tab_rl",
        "name": "Parsear y Enviar Malla",
        "func": "// Convierte las filas del CSV en array [[v1,v2,w],...] y lo envía al heatmap\nvar rows = Array.isArray(msg.payload) ? msg.payload : [msg.payload];\nvar grid = rows.map(function(r) {\n    return [parseFloat(r.var1), parseFloat(r.var2), parseFloat(r.w)];\n}).filter(function(r){ return !isNaN(r[0]) && !isNaN(r[1]) && !isNaN(r[2]); });\nflow.set('rl_grid', grid);\nnode.status({fill:'green', shape:'dot', text: grid.length+' celdas ✓'});\nnode.warn('Malla cargada — '+grid.length+' celdas');\nmsg.payload = {type: 'grid', data: grid};\nreturn msg;\n",
        "outputs": 1,
        "timeout": "",
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 850,
        "y": 180,
        "wires": [
            [
                "rl_tpl_heatmap"
            ]
        ]
    },
    {
        "id": "rl_tpl_heatmap",
        "type": "ui_template",
        "z": "tab_rl",
        "group": "grp_rl_heatmap",
        "name": "Mapa de Calor + Recorrido",
        "order": 1,
        "width": 0,
        "height": 0,
        "format": "<style>\n.rl-title{color:#7ecfff;font-size:12px;font-weight:700;margin-bottom:6px;letter-spacing:.4px;}\ncanvas{border-radius:6px;display:block;}\n.btn-rl{padding:6px 16px;border:none;border-radius:5px;font-size:12px;font-weight:700;cursor:pointer;color:#fff;margin:3px;transition:.15s;}\n.btn-rl:hover{opacity:.82;}\n.spd{padding:4px 10px;border:1px solid #444;border-radius:4px;background:#1a1d27;color:#aaa;font-size:10px;cursor:pointer;margin:2px;}\n.spd.on{background:#2980b9;color:#fff;border-color:#2980b9;}\n#rl-prog-bar{height:5px;background:#222;border-radius:3px;margin:6px 0;}\n#rl-prog-fill{height:100%;background:linear-gradient(90deg,#27ae60,#7ecfff);border-radius:3px;width:0%;transition:width .08s;}\n</style>\n<div style=\"font-family:'Roboto',sans-serif;padding:10px;background:#0f1117;border-radius:8px;\">\n  <div class=\"rl-title\">Malla de Optimización + Recorrido del Agente RL</div>\n  <div style=\"display:flex;align-items:center;flex-wrap:wrap;margin-bottom:8px;gap:2px;\">\n    <button class=\"btn-rl\" style=\"background:#27ae60;\" onclick=\"rlPlay()\">▶ Play</button>\n    <button class=\"btn-rl\" style=\"background:#e67e22;\" onclick=\"rlPause()\">⏸ Pause</button>\n    <button class=\"btn-rl\" style=\"background:#e74c3c;\" onclick=\"rlReset()\">⟳ Reset</button>\n    <span style=\"color:#666;font-size:10px;margin-left:10px;\">Velocidad:</span>\n    <button class=\"spd on\" onclick=\"rlSpd(1,this)\">×1</button>\n    <button class=\"spd\"    onclick=\"rlSpd(2,this)\">×2</button>\n    <button class=\"spd\"    onclick=\"rlSpd(5,this)\">×5</button>\n    <button class=\"spd\"    onclick=\"rlSpd(10,this)\">×10</button>\n    <button class=\"spd\"    onclick=\"rlSpd(50,this)\">×50</button>\n    <span id=\"rl-stepinfo\" style=\"color:#7ecfff;font-size:11px;font-weight:700;margin-left:12px;\">Esperando datos…</span>\n  </div>\n  <div id=\"rl-prog-bar\"><div id=\"rl-prog-fill\"></div></div>\n  <canvas id=\"rl-hm\" width=\"740\" height=\"400\"></canvas>\n  <div style=\"margin-top:6px;display:flex;gap:16px;font-size:10px;color:#888;\">\n    <span>🟢 Inicio &nbsp; 🔴 Agente &nbsp; ⭐ Mínimo global (454, 208) w=20.535</span>\n    <span style=\"margin-left:auto;\">Paleta: azul→verde→amarillo→rojo (w bajo→alto)</span>\n  </div>\n</div>\n<script>\n(function(){\n// ── Datos dinámicos (se cargan desde los nodos CSV) ──────────────────────────\nvar GRID = [];\nvar PATH = [];\nvar W_MIN=20.5352,W_MAX=23.0561,V1_MAX=762,V2_MAX=458;\nvar GMIN={v1:454,v2:208,w:20.5352};\nvar step=0,spd=1,timer=null;\n\nvar cv=document.getElementById('rl-hm'),ctx=cv.getContext('2d');\nvar CW=cv.width,CH=cv.height;\nvar P={l:38,r:16,t:8,b:26};\nvar PW=CW-P.l-P.r,PH=CH-P.t-P.b;\n\nfunction px(v1,v2){return{x:P.l+(v1/V1_MAX)*PW,y:P.t+(1-v2/V2_MAX)*PH};}\n\nfunction wCol(w){\n  var t=(w-W_MIN)/(W_MAX-W_MIN),r,g,b;\n  if(t<0.25){r=68;g=Math.round(1+t*4*85);b=Math.round(84+t*4*80);}\n  else if(t<0.5){var s=(t-0.25)*4;r=Math.round(s*49);g=Math.round(86+s*82);b=Math.round(164-s*100);}\n  else if(t<0.75){var s=(t-0.5)*4;r=Math.round(49+s*174);g=Math.round(168+s*25);b=Math.round(64-s*30);}\n  else{var s=(t-0.75)*4;r=Math.round(223+s*30);g=Math.round(193-s*100);b=Math.round(34-s*20);}\n  return'rgb('+Math.min(255,Math.max(0,r))+','+Math.min(255,Math.max(0,g))+','+Math.min(255,Math.max(0,b))+')';\n}\n\n// Canvas offscreen para el fondo (malla)\nvar off=document.createElement('canvas');off.width=CW;off.height=CH;\nvar octx=off.getContext('2d');\n\nfunction rebuildBackground(){\n  octx.fillStyle='#111';octx.fillRect(0,0,CW,CH);\n  for(var i=0;i<GRID.length;i++){\n    var p=px(GRID[i][0],GRID[i][1]);\n    octx.fillStyle=wCol(GRID[i][2]);\n    octx.fillRect(p.x-2,p.y-2,4,4);\n  }\n  octx.strokeStyle='#333';octx.lineWidth=1;\n  octx.beginPath();octx.moveTo(P.l,P.t);octx.lineTo(P.l,P.t+PH);octx.stroke();\n  octx.beginPath();octx.moveTo(P.l,P.t+PH);octx.lineTo(P.l+PW,P.t+PH);octx.stroke();\n  octx.fillStyle='#555';octx.font='9px Roboto';octx.textAlign='center';\n  for(var v=0;v<=V1_MAX;v+=150){var p=px(v,0);octx.fillText(v,p.x,P.t+PH+14);}\n  octx.textAlign='right';\n  for(var v=0;v<=V2_MAX;v+=100){var p=px(0,v);octx.fillText(v,P.l-3,p.y+3);}\n}\n\nfunction draw(){\n  ctx.drawImage(off,0,0);\n  // Trazar el recorrido hasta el paso actual\n  if(PATH.length>1){\n    var pts=PATH.slice(0,step+1);\n    ctx.beginPath();ctx.strokeStyle='rgba(255,255,255,0.6)';ctx.lineWidth=1.5;\n    var s0=px(pts[0][1],pts[0][2]);ctx.moveTo(s0.x,s0.y);\n    for(var i=1;i<pts.length;i++){var pi=px(pts[i][1],pts[i][2]);ctx.lineTo(pi.x,pi.y);}\n    ctx.stroke();\n  }\n  // Mínimo global\n  var gm=px(GMIN.v1,GMIN.v2);\n  ctx.beginPath();ctx.arc(gm.x,gm.y,7,0,Math.PI*2);\n  ctx.strokeStyle='#f1c40f';ctx.lineWidth=2.5;ctx.stroke();\n  ctx.fillStyle='rgba(241,196,15,0.2)';ctx.fill();\n  ctx.fillStyle='#f1c40f';ctx.font='bold 9px Roboto';ctx.textAlign='left';ctx.fillText('MIN★',gm.x+9,gm.y+3);\n  if(PATH.length>0){\n    // Punto de inicio\n    var s0=px(PATH[0][1],PATH[0][2]);\n    ctx.beginPath();ctx.arc(s0.x,s0.y,4,0,Math.PI*2);ctx.fillStyle='#2ecc71';ctx.fill();\n    // Agente actual\n    if(step<PATH.length){\n      var cur=PATH[step];var cp=px(cur[1],cur[2]);\n      ctx.beginPath();ctx.arc(cp.x,cp.y,5,0,Math.PI*2);ctx.fillStyle='#e74c3c';ctx.fill();\n      ctx.strokeStyle='#fff';ctx.lineWidth=1.5;ctx.stroke();\n    }\n    var pct=(PATH.length>1?(step/(PATH.length-1)*100):0).toFixed(1);\n    var progFill=document.getElementById('rl-prog-fill');\n    var stepInfo=document.getElementById('rl-stepinfo');\n    if(progFill) progFill.style.width=pct+'%';\n    if(stepInfo) stepInfo.textContent='Paso '+(PATH[step]?PATH[step][0]:0)+' / '+(PATH.length-1);\n  }\n}\n\nfunction tick(){\n  if(!PATH.length||step>=PATH.length-1){clearInterval(timer);timer=null;return;}\n  step=Math.min(step+spd,PATH.length-1);\n  draw();\n}\n\n// ── API pública expuesta al DOM (botones del template) ────────────────────────\nwindow.rlPlay  = function(){if(PATH.length&&!timer)timer=setInterval(tick,40);};\nwindow.rlPause = function(){clearInterval(timer);timer=null;};\nwindow.rlReset = function(){rlPause();step=0;draw();};\nwindow.rlSpd   = function(s,b){\n  spd=s;\n  document.querySelectorAll('.spd').forEach(function(x){x.classList.remove('on');});\n  b.classList.add('on');\n};\n// ── API para otros templates (gráfico w, ticker) ──────────────────────────────\nwindow.rlGetStep = function(){return step;};\nwindow.rlGetPath = function(){return PATH;};\n\n// ── Puntos de entrada para carga de datos ────────────────────────────────────\nwindow._rl_loadGrid = function(data){\n  GRID = data;\n  rebuildBackground();\n  draw();\n  node&&node.status&&node.status({fill:'green',shape:'dot',text:'Malla pintada'});\n};\nwindow._rl_loadPath = function(data){\n  PATH = data;\n  step = 0;\n  draw();\n};\n\n// Dibujo inicial (canvas vacío)\nrebuildBackground();\ndraw();\n\n})();\n\n// ── Handler de mensajes Angular (recibe datos de los nodos CSV) ───────────────\nscope.$watch('msg', function(msg){\n  if(!msg || !msg.payload) return;\n  var d = msg.payload;\n  if(d.type === 'grid' && window._rl_loadGrid) window._rl_loadGrid(d.data);\n  else if(d.type === 'path' && window._rl_loadPath) window._rl_loadPath(d.data);\n});\n</script>",
        "storeOutMessages": false,
        "fwdInMessages": true,
