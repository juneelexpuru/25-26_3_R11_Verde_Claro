    {
        "id": "rl_csv_path",
        "type": "csv",
        "z": "tab_rl",
        "name": "Parse Recorrido",
        "sep": ",",
        "hdrin": true,
        "hdrout": "all",
        "multi": "mult",
        "ret": "\n",
        "temp": "indice,var1,var2,w",
        "skip": "0",
        "strings": true,
        "include_empty_strings": false,
        "include_null_values": false,
