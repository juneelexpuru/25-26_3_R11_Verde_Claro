    {
        "id": "rl_fn_store_path",
        "type": "function",
        "z": "tab_rl",
        "name": "Almacenar y Enviar Recorrido",
        "func": "// Parsea el recorrido, lo guarda en flow context y lo envía al heatmap\nvar rows = Array.isArray(msg.payload) ? msg.payload : [msg.payload];\nvar path = rows.map(function(r) {\n    return { idx: parseInt(r.indice), v1: parseInt(parseFloat(r.var1)),\n             v2: parseInt(parseFloat(r.var2)), w: parseFloat(r.w) };\n}).filter(function(r){ return !isNaN(r.idx); });\npath.sort(function(a,b){return a.idx-b.idx;});\nflow.set('rl_path', path);\nflow.set('rl_step', 0);\nflow.set('rl_bestW', Infinity);\nnode.status({fill:'green', shape:'dot', text: path.length+' pasos cargados ✓'});\nnode.warn('Recorrido RL cargado — '+path.length+' pasos');\n// Convertir a formato de array [idx, v1, v2, w] para el template\nvar pathArr = path.map(function(r){ return [r.idx, r.v1, r.v2, r.w]; });\nmsg.payload = {type: 'path', data: pathArr};\nreturn msg;\n",
        "outputs": 1,
        "timeout": "",
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 890,
        "y": 100,
        "wires": [
            [
                "rl_tpl_heatmap"
            ]
        ]
