    {
        "id": "rl_tpl_wchart",
        "type": "ui_template",
        "z": "tab_rl",
        "group": "grp_rl_wvis",
        "name": "Gráfico w Visual",
        "order": 1,
        "width": 0,
        "height": 0,
        "format": "<div style=\"font-family:'Roboto',sans-serif;padding:10px;background:#0f1117;border-radius:8px;\">\n  <div style=\"color:#7ecfff;font-size:12px;font-weight:700;margin-bottom:6px;\">Evolución de w (función objetivo)</div>\n  <canvas id=\"rl-wc\" width=\"340\" height=\"220\"></canvas>\n</div>\n<script>\n(function(){\nvar cv=document.getElementById('rl-wc'),ctx=cv.getContext('2d');\nvar W=cv.width,H=cv.height,P={l:38,r:10,t:8,b:22};\nvar PW=W-P.l-P.r,PH=H-P.t-P.b;\nvar W_MIN=20.5352,W_MAX=23.0561,GMIN_W=20.5352;\nfunction drawW(upToStep){\n  ctx.clearRect(0,0,W,H);\n  ctx.fillStyle='#0f1117';ctx.fillRect(0,0,W,H);\n  var rng=W_MAX-W_MIN;\n  ctx.strokeStyle='#1e2030';ctx.lineWidth=1;\n  for(var i=0;i<=4;i++){var y=P.t+(i/4)*PH;ctx.beginPath();ctx.moveTo(P.l,y);ctx.lineTo(P.l+PW,y);ctx.stroke();\n    ctx.fillStyle='#555';ctx.font='9px Roboto';ctx.textAlign='right';\n    ctx.fillText((W_MAX-(i/4)*rng).toFixed(1),P.l-3,y+3);}\n  var yg=P.t+((W_MAX-GMIN_W)/rng)*PH;\n  ctx.strokeStyle='rgba(241,196,15,0.35)';ctx.lineWidth=1;ctx.setLineDash([3,4]);\n  ctx.beginPath();ctx.moveTo(P.l,yg);ctx.lineTo(P.l+PW,yg);ctx.stroke();\n  ctx.setLineDash([]);ctx.fillStyle='rgba(241,196,15,0.6)';ctx.font='8px Roboto';ctx.textAlign='left';\n  ctx.fillText('mín='+GMIN_W,P.l+2,yg-2);\n  if(!window.rlGetPath) return;\n  var PATH=window.rlGetPath();\n  if(!PATH || PATH.length < 2) return;\n  var TOTAL=PATH.length-1;\n  var pts=PATH.slice(0,upToStep+1);\n  if(pts.length<2) return;\n  ctx.beginPath();ctx.strokeStyle='#7ecfff';ctx.lineWidth=1.5;\n  for(var i=0;i<pts.length;i++){\n    var x=P.l+(pts[i][0]/TOTAL)*PW,y=P.t+((W_MAX-pts[i][3])/rng)*PH;\n    i===0?ctx.moveTo(x,y):ctx.lineTo(x,y);}\n  ctx.stroke();\n  var last=pts[pts.length-1];\n  var lx=P.l+(last[0]/TOTAL)*PW,ly=P.t+((W_MAX-last[3])/rng)*PH;\n  ctx.beginPath();ctx.arc(lx,ly,3,0,Math.PI*2);ctx.fillStyle='#e74c3c';ctx.fill();\n  ctx.fillStyle='#666';ctx.font='9px Roboto';ctx.textAlign='center';\n  var step0=Math.round(TOTAL/4);\n  for(var v=0;v<=TOTAL;v+=step0){ctx.fillText(v,P.l+(v/TOTAL)*PW,P.t+PH+14);}\n}\nwindow.rlDrawW=drawW;\ndrawW(0);\nsetInterval(function(){if(window.rlGetStep)drawW(window.rlGetStep());},80);\n})();\n</script>",
