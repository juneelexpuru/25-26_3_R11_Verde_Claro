    {
        "id": "norm_csv_norm",
        "type": "csv",
        "z": "tab_norm_flow",
        "name": "Parse Normal",
        "sep": ",",
        "hdrin": false,
        "hdrout": "all",
        "multi": "mult",
        "ret": "\n",
        "temp": "tachometer,acc_under_axial,acc_under_radiale,acc_under_tangencial,acc_over_axial,acc_over_radiale,acc_over_tangencial,microphone",
        "skip": "0",
        "strings": true,
        "include_empty_strings": false,
        "include_null_values": false,
        "x": 630,
        "y": 100,
        "wires": [
            [
                "norm_fn_store"
            ]
        ]
    },
    {
        "id": "norm_fn_store",
        "type": "function",
        "z": "tab_norm_flow",
        "name": "Almacenar Rows Normal",
        "func": "var rows = Array.isArray(msg.payload) ? msg.payload : [msg.payload];\nvar COLS = ['tachometer','acc_under_axial','acc_under_radiale','acc_under_tangencial',\n            'acc_over_axial','acc_over_radiale','acc_over_tangencial','microphone'];\nvar parsed = rows.map(function(r){\n    var obj = {};\n    COLS.forEach(function(k){ var v=parseFloat(r[k]); obj[k]=isFinite(v)?v:0; });\n    return obj;\n}).filter(function(r){ return r.tachometer !== undefined; });\n\nif (parsed.length === 0) { node.warn('CSV vacío'); return null; }\nflow.set('rows_Normal_cmp', parsed);\nnode.status({fill:'green', shape:'dot', text:'Normal: '+parsed.length+' filas ✓'});\nnode.warn('Cargado Normal (comparación) — ' + parsed.length + ' filas');\nreturn null;",
        "outputs": 1,
        "timeout": "",
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 860,
        "y": 100,
        "wires": [
            []
        ]
    },
