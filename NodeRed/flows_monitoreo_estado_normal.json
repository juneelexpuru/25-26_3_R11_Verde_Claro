    {
        "id": "norm_ctrl_info",
        "type": "ui_template",
        "z": "tab_norm_flow",
        "group": "grp_ctrl_norm",
        "name": "Info Comparación",
        "order": 1,
        "width": 0,
        "height": 0,
        "format": "<div style=\"font-family:'Roboto',sans-serif;padding:8px;\">\n  <div style=\"margin-bottom:8px;font-size:12px;font-weight:700;color:#1e8449;\">\n   Dashboard de Referencia — Solo datos Normales\n  </div>\n  <div style=\"background:#eafaf1;border-radius:6px;padding:8px;font-size:11px;line-height:1.8;\">\n    Este flujo replica exactamente la lógica del flujo principal<br/>\n    pero <b>sin inyectar fallos</b>. Su uso es unicamente como línea base <br/>\n    para comparar como debería comportarse un rodamiento normal sin fallos<br/>\n    visualmente cómo se comportan RMS, Kurtosis y Crest Factor<br/>\n    cuando el rodamiento está en estado <b style=\"color:#1e8449;\">normal</b>.\n  </div>\n</div>",
