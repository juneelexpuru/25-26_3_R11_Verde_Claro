    {
        "id": "norm_fn_ctrl",
        "type": "function",
        "z": "tab_norm_flow",
        "name": "Control Start/Stop Normal",
        "func": "var start = (msg.payload !== 'stop');\nflow.set('streaming_norm', start);\nif (start) {\n    flow.set('totalTicks_norm', 0);\n    node.status({fill:'green', shape:'ring', text:'▶ Activo'});\n} else {\n    node.status({fill:'red', shape:'dot', text:'⏹ Parado'});\n}\nreturn null;",
        "outputs": 1,
        "timeout": "",
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 510,
        "y": 280,
        "wires": [
            []
        ]
    },
    {
        "id": "norm_ticker",
        "type": "inject",
        "z": "tab_norm_flow",
        "name": "Tick 250 ms",
        "props": [
            {
                "p": "payload"
            }
        ],
        "repeat": "1",
        "crontab": "",
        "once": false,
        "onceDelay": 0.1,
        "topic": "",
        "payload": "",
        "payloadType": "date",
        "x": 190,
        "y": 440,
        "wires": [
            [
                "norm_fn_sampler"
            ]
        ]
    },
    {
        "id": "norm_fn_sampler",
        "type": "function",
        "z": "tab_norm_flow",
        "name": "Sampler 100% Normal + Ventana Deslizante",
        "func": "// Fires every 0.25 s — sólo datos Normal, sin fallos.\nif (!flow.get('streaming_norm')) { return null; }\n\nvar rows_N = flow.get('rows_Normal_cmp') || [];\nif (rows_N.length === 0) {\n    node.warn('Carga primero el CSV Normal.');\n    return null;\n}\n\n// Siempre Normal — sin mezcla de fallos\nvar row = rows_N[Math.floor(Math.random() * rows_N.length)];\n\n// Rolling window (256 samples)\nvar buf = context.get('buf') || [];\nbuf.push(row);\nif (buf.length > 256) buf.shift();\ncontext.set('buf', buf);\n\n// Helpers estadísticos\nfunction col(c){ return buf.map(function(r){ var v=parseFloat(r[c]); return isFinite(v)?v:0; }); }\nfunction mean(a){ return a.reduce(function(s,x){return s+x;},0)/a.length; }\nfunction rms(a){  return Math.sqrt(a.reduce(function(s,x){return s+x*x;},0)/a.length); }\nfunction std(a){  var m=mean(a); return Math.sqrt(a.reduce(function(s,x){return s+Math.pow(x-m,2);},0)/a.length); }\nfunction kurt(a){ var m=mean(a),s=std(a); if(s<1e-14)return 3;\n                  return a.reduce(function(t,x){return t+Math.pow((x-m)/s,4);},0)/a.length; }\nfunction absMax(a){ return a.reduce(function(s,x){return Math.abs(x)>s?Math.abs(x):s;},0); }\nfunction crest(a){ var r2=rms(a); return r2<1e-14?0:absMax(a)/r2; }\nfunction dc(a){   var m=mean(a); return a.map(function(x){return x-m;}); }\nfunction sf(v){   var n=parseFloat(v); return isFinite(n)?n:0; }\n\nvar ACOLS = ['acc_under_axial','acc_under_radiale','acc_under_tangencial',\n             'acc_over_axial','acc_over_radiale','acc_over_tangencial'];\nvar maxKurt=0, sumCrest=0, sumRMS=0;\nvar perCh = {};\nACOLS.forEach(function(c){\n    var v = dc(col(c));\n    var k = sf(kurt(v)), cr = sf(crest(v)), rv = sf(rms(v));\n    if(k > maxKurt) maxKurt = k;\n    sumCrest += cr; sumRMS += rv;\n    perCh[c] = { rms:+rv.toFixed(6), kurtosis:+k.toFixed(4), crest:+cr.toFixed(4) };\n});\nvar meanCrest = +(sumCrest / ACOLS.length).toFixed(4);\nvar meanRMS   = +(sumRMS   / ACOLS.length).toFixed(6);\n\nvar total = (flow.get('totalTicks_norm') || 0) + 1;\nflow.set('totalTicks_norm', total);\n\nvar t = Date.now();\nmsg.payload = {\n    source:       'Normal',\n    is_fault:     false,\n    timestamp:    t,\n    buf_size:     buf.length,\n    max_kurtosis: +maxKurt.toFixed(4),\n    mean_crest:   meanCrest,\n    mean_rms:     meanRMS,\n    per_channel:  perCh,\n    fault_rate:   0,\n    total_ticks:  total\n};\nreturn msg;\n",
        "outputs": 1,
        "timeout": "",
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 510,
        "y": 440,
        "wires": [
            [
                "norm_fmt_rms",
                "norm_fmt_kurt",
                "norm_fmt_crest",
                "norm_fmt_multi"
            ]
        ]
    },
    {
        "id": "norm_fmt_rms",
        "type": "function",
        "z": "tab_norm_flow",
        "name": "fmt RMS",
        "func": "msg.topic   = 'Normal';\nmsg.payload = msg.payload.mean_rms;\nreturn msg;",
        "outputs": 1,
        "timeout": "",
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 840,
        "y": 340,
        "wires": [
