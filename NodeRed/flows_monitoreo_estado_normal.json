                "norm_chart_rms"
            ]
        ]
    },
    {
        "id": "norm_fmt_kurt",
        "type": "function",
        "z": "tab_norm_flow",
        "name": "fmt Kurtosis + Umbral",
        "func": "var d = msg.payload;\nmsg.topic   = 'Normal';\nmsg.payload = d.max_kurtosis;\nnode.send(msg);\nnode.send({ topic: 'Umbral K=3', payload: 3 });\nreturn null;",
        "outputs": 1,
        "timeout": "",
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 840,
        "y": 400,
        "wires": [
            [
                "norm_chart_kurt"
            ]
        ]
    },
    {
        "id": "norm_fmt_crest",
        "type": "function",
        "z": "tab_norm_flow",
        "name": "fmt Crest + Ref",
        "func": "var d = msg.payload;\nmsg.topic   = 'Normal';\nmsg.payload = d.mean_crest;\nnode.send(msg);\nnode.send({ topic: 'Ref. Normal', payload: 1.4 });\nreturn null;",
        "outputs": 1,
        "timeout": "",
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 840,
        "y": 460,
        "wires": [
            [
                "norm_chart_crest"
            ]
        ]
    },
    {
        "id": "norm_fmt_multi",
        "type": "function",
        "z": "tab_norm_flow",
        "name": "fmt Multi-Canal",
        "func": "var d = msg.payload;\nObject.keys(d.per_channel).forEach(function(ch){\n    node.send({\n        topic:   ch.replace('acc_','').replace(/_/g,' '),\n        payload: d.per_channel[ch].rms\n    });\n});\nreturn null;",
        "outputs": 1,
        "timeout": "",
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
