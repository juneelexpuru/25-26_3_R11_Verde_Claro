    {
        "id": "rt_fn_store",
        "type": "function",
        "z": "tab_rt_flow",
        "name": "Almacenar Rows en Global",
        "func": "var label = msg.label || 'unknown';\nvar rows  = Array.isArray(msg.payload) ? msg.payload : [msg.payload];\nvar COLS = ['tachometer','acc_under_axial','acc_under_radiale','acc_under_tangencial',\n            'acc_over_axial','acc_over_radiale','acc_over_tangencial','microphone'];\nvar parsed = rows.map(function(r){\n    var obj = {};\n    COLS.forEach(function(k){ var v=parseFloat(r[k]); obj[k]=isFinite(v)?v:0; });\n    return obj;\n}).filter(function(r){ return r.tachometer !== undefined; });\n\nif (parsed.length === 0) { node.warn('CSV vacío para ' + label); return null; }\nglobal.set('rows_' + label, parsed);\nnode.status({fill:'green', shape:'dot', text: label+': '+parsed.length+' filas ✓'});\nnode.warn('Cargado ' + label + ' — ' + parsed.length + ' filas');\nreturn null;",
        "outputs": 1,
        "timeout": "",
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 1160,
        "y": 180,
        "wires": [
            []
        ]
    },
