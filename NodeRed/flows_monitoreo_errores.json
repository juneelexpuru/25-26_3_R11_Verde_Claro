    {
        "id": "rt_fn_ctrl",
        "type": "function",
        "z": "tab_rt_flow",
        "name": "Control Start/Stop",
        "func": "var start = (msg.payload !== 'stop');\nglobal.set('streaming', start);\nif (start) {\n    flow.set('totalTicks', 0);\n    flow.set('faultTicks', 0);\n    flow.set('faultLog',   []);\n    node.status({fill:'green', shape:'ring', text:'▶ Activo'});\n} else {\n    node.status({fill:'red', shape:'dot', text:'⏹ Parado'});\n}\nreturn null;",
        "outputs": 1,
        "timeout": "",
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 420,
        "y": 390,
        "wires": [
            []
        ]
    },
    {
        "id": "rt_ticker",
        "type": "inject",
        "z": "tab_rt_flow",
        "name": "Tick 250 ms",
        "props": [
            {
                "p": "payload"
            }
        ],
        "repeat": "1",
        "crontab": "",
        "once": false,
        "onceDelay": 0.1,
        "topic": "",
        "payload": "",
        "payloadType": "date",
        "x": 190,
        "y": 540,
        "wires": [
            [
                "rt_fn_sampler"
            ]
        ]
    },
    {
        "id": "rt_fn_sampler",
        "type": "function",
        "z": "tab_rt_flow",
        "name": "Sampler 94/3/3 + Ventana Deslizante",
        "func": "\n// Fires every 0.25 s (inject repeat).\n// Picks one row from the mixed distribution (94/3/3),\n// appends to a rolling buffer, computes window metrics.\n\nif (!global.get('streaming')) { return null; }\n\nvar rows_N = global.get('rows_Normal')       || [];\nvar rows_M = global.get('rows_Misalignment') || [];\nvar rows_I = global.get('rows_Imbalance')    || [];\n\nif (rows_N.length === 0) {\n    node.warn('Carga los tres CSVs primero (Normal, Misalignment, Imbalance).');\n    return null;\n}\n\n// ── Source selection 94 / 3 / 3 ───────────────────────────────────────────\nvar r = Math.random();\nvar source, pool;\nif      (r < 0.94) { source = 'Normal';       pool = rows_N; }\nelse if (r < 0.97) { source = 'Misalignment'; pool = rows_M.length ? rows_M : rows_N; }\nelse               { source = 'Imbalance';    pool = rows_I.length ? rows_I : rows_N; }\n\nvar row = pool[Math.floor(Math.random() * pool.length)];\n\n// ── Rolling window (256 samples) ──────────────────────────────────────────\nvar buf = context.get('buf') || [];\nbuf.push(row);\nif (buf.length > 256) buf.shift();\ncontext.set('buf', buf);\n\n// ── Fault history — last 100 ticks for fault-rate % ───────────────────────\nvar fh = context.get('fh') || [];\nfh.push(source !== 'Normal' ? 1 : 0);\nif (fh.length > 100) fh.shift();\ncontext.set('fh', fh);\nvar faultRate = fh.length\n    ? +(fh.reduce(function(s,x){return s+x;},0) / fh.length * 100).toFixed(1)\n    : 0;\n\n// ── Statistical helpers ────────────────────────────────────────────────────\nfunction col(c){ return buf.map(function(r){ var v=parseFloat(r[c]); return isFinite(v)?v:0; }); }\nfunction mean(a){ return a.reduce(function(s,x){return s+x;},0)/a.length; }\nfunction rms(a){  return Math.sqrt(a.reduce(function(s,x){return s+x*x;},0)/a.length); }\nfunction std(a){  var m=mean(a); return Math.sqrt(a.reduce(function(s,x){return s+Math.pow(x-m,2);},0)/a.length); }\nfunction kurt(a){ var m=mean(a),s=std(a); if(s<1e-14)return 3;\n                  return a.reduce(function(t,x){return t+Math.pow((x-m)/s,4);},0)/a.length; }\nfunction absMax(a){ return a.reduce(function(s,x){return Math.abs(x)>s?Math.abs(x):s;},0); }\nfunction crest(a){ var r2=rms(a); return r2<1e-14?0:absMax(a)/r2; }\nfunction dc(a){    var m=mean(a); return a.map(function(x){return x-m;}); }\nfunction sf(v){    var n=parseFloat(v); return isFinite(n)?n:0; }\n\n// ── Per-channel metrics on window ─────────────────────────────────────────\nvar ACOLS = ['acc_under_axial','acc_under_radiale','acc_under_tangencial',\n             'acc_over_axial','acc_over_radiale','acc_over_tangencial'];\nvar maxKurt=0, sumCrest=0, sumRMS=0;\nvar perCh = {};\nACOLS.forEach(function(c){\n    var v = dc(col(c));\n    var k = sf(kurt(v)), cr = sf(crest(v)), rv = sf(rms(v));\n    if(k > maxKurt) maxKurt = k;\n    sumCrest += cr; sumRMS += rv;\n    perCh[c] = { rms:+rv.toFixed(6), kurtosis:+k.toFixed(4), crest:+cr.toFixed(4) };\n});\nvar meanCrest = +(sumCrest / ACOLS.length).toFixed(4);\nvar meanRMS   = +(sumRMS   / ACOLS.length).toFixed(6);\n\n// ── Tick counters (persist across calls via flow context) ─────────────────\nvar total  = (flow.get('totalTicks') || 0) + 1;\nvar faults = (flow.get('faultTicks') || 0) + (source !== 'Normal' ? 1 : 0);\nflow.set('totalTicks', total);\nflow.set('faultTicks', faults);\n\n// ── Fault log (last 20 events) ────────────────────────────────────────────\nvar isFault = source !== 'Normal';\nif (isFault) {\n    var log = flow.get('faultLog') || [];\n    log.unshift({ t: new Date().toLocaleTimeString(), source: source,\n                  kurtosis: +maxKurt.toFixed(3), crest: +meanCrest.toFixed(3) });\n    if (log.length > 20) log.pop();\n    flow.set('faultLog', log);\n}\n\nvar t = Date.now();\nmsg.payload = {\n    source:      source,\n    is_fault:    isFault,\n    timestamp:   t,\n    buf_size:    buf.length,\n    max_kurtosis:+maxKurt.toFixed(4),\n    mean_crest:  meanCrest,\n    mean_rms:    meanRMS,\n    per_channel: perCh,\n    fault_rate:  faultRate,\n    total_ticks: total,\n    fault_ticks: faults,\n    fault_log:   flow.get('faultLog') || []\n};\nreturn msg;\n",
        "outputs": 1,
        "timeout": "",
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 440,
        "y": 540,
        "wires": [
            [
                "rt_fmt_rms",
                "rt_fmt_kurt",
                "rt_fmt_crest",
                "rt_fmt_multi",
                "rt_fmt_gauge"
            ]
        ]
    },
